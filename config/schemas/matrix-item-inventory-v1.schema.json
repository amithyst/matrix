{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://matrix.local/schemas/matrix-item-inventory-v1.schema.json",
  "title": "Matrix Item Inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "inventory"],
  "properties": {
    "schema": {"const": "matrix-item-inventory/v1"},
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inventory_id", "entries"],
      "properties": {
        "inventory_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": {"$ref": "#/$defs/entry"}
        }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]{0,127}$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "pack_digest",
        "item_id",
        "pool_size",
        "spawn"
      ],
      "properties": {
        "slot_id": {"$ref": "#/$defs/identifier"},
        "pack_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "item_id": {"$ref": "#/$defs/identifier"},
        "pool_size": {"type": "integer", "minimum": 1, "maximum": 32},
        "spawn": {
          "type": "object",
          "additionalProperties": false,
          "required": ["distance_m", "height_m", "quaternion_wxyz"],
          "properties": {
            "distance_m": {"type": "number", "minimum": 0, "maximum": 1000},
            "height_m": {
              "type": "number",
              "minimum": -1000,
              "maximum": 1000
            },
            "quaternion_wxyz": {
              "type": "array",
              "minItems": 4,
              "maxItems": 4,
              "items": {"type": "number"}
            }
          }
        }
      }
    }
  }
}
