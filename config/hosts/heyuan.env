# Shared, non-secret defaults for the Heyuan RTX 4090 host.
export MATRIX_HOST_PROFILE="heyuan"
export DISPLAY="${DISPLAY:-:1001}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"

# GPU0 is attached to NUMA node 0 on the dual-socket EPYC host.
export MATRIX_CPUSET="${MATRIX_CPUSET:-0-63,128-191}"

export MATRIX_RUNTIME_ROOT="${MATRIX_RUNTIME_ROOT:-$MATRIX_PROJECT_ROOT/outputs/runtime/matrix-sonic-native-v2}"
export MATRIX_SONIC_ROOT="${MATRIX_SONIC_ROOT:-$HOME/GR00T-WholeBodyControl}"
export MATRIX_BOOTSTRAP_PYTHON="${MATRIX_BOOTSTRAP_PYTHON:-python3.10}"
export MATRIX_ROS_PREFIX="${MATRIX_ROS_PREFIX:-$MATRIX_RUNTIME_ROOT/ros2-humble-prefix}"
export MATRIX_NATIVE_DEPS_ROOT="${MATRIX_NATIVE_DEPS_ROOT:-$MATRIX_RUNTIME_ROOT/matrix-native-deps}"
export MATRIX_UE_MAX_FPS="${MATRIX_UE_MAX_FPS:-60}"
