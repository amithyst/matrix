# Shared, non-secret defaults for the TRNA RTX 5080 Laptop host.
export MATRIX_HOST_PROFILE="trna"
export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-/run/user/$(id -u)/gdm/Xauthority}"
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"
export MATRIX_CPUSET="${MATRIX_CPUSET:-}"

# Keep tmux/Conda shell state out of the locked runtime dependency closure.
unset LD_LIBRARY_PATH PYTHONPATH

export MATRIX_RUNTIME_ROOT="${MATRIX_RUNTIME_ROOT:-$MATRIX_PROJECT_ROOT/outputs/runtime/matrix-sonic-native-v2}"
export MATRIX_SONIC_ROOT="${MATRIX_SONIC_ROOT:-$HOME/worktrees/sonic-matrix-recovery-v77}"
export MATRIX_BOOTSTRAP_PYTHON="${MATRIX_BOOTSTRAP_PYTHON:-python3.10}"
export MATRIX_ROS_PREFIX="${MATRIX_ROS_PREFIX:-/opt/ros/humble}"
export MATRIX_NATIVE_DEPS_ROOT="${MATRIX_NATIVE_DEPS_ROOT:-$MATRIX_RUNTIME_ROOT/matrix-native-deps}"
export MATRIX_UE_MAX_FPS="${MATRIX_UE_MAX_FPS:-60}"

# Shared TRNA operator defaults. Previously loaded overrides remain authoritative,
# and explicit launcher arguments still win after the profile is loaded.
export MATRIX_SONIC_CONTROL_SOURCE="${MATRIX_SONIC_CONTROL_SOURCE:-game}"
export MATRIX_GAME_INPUT_SOURCE="${MATRIX_GAME_INPUT_SOURCE:-keyboard}"
export MATRIX_GAME_CAMERA_YAW_SOURCE="${MATRIX_GAME_CAMERA_YAW_SOURCE:-ue-final-pov}"
export MATRIX_GAME_LOOK_BUTTON="${MATRIX_GAME_LOOK_BUTTON:-left}"
export MATRIX_GAME_MOUSE_SENSITIVITY_DEG="${MATRIX_GAME_MOUSE_SENSITIVITY_DEG:-0.12}"
export MATRIX_GAME_CAMERA_YAW_SIGN="${MATRIX_GAME_CAMERA_YAW_SIGN:--1}"
export MATRIX_GAME_CAMERA_YAW_OFFSET_DEG="${MATRIX_GAME_CAMERA_YAW_OFFSET_DEG:-0.0}"
# An explicitly empty inherited value keeps the signed overlay disabled for a
# recovery/debug launch.
export MATRIX_CENTERED_CAMERA_OVERLAY_BUNDLE="${MATRIX_CENTERED_CAMERA_OVERLAY_BUNDLE-$HOME/matrix-artifacts/matrix-centered-camera-custom-v1}"

# TRNA recovery test deployment. Keep the persistent world enabled, while
# physical recovery owns the fall path instead of the cold auto-respawn loop.
export MATRIX_GAME_AUTO_RESPAWN="${MATRIX_GAME_AUTO_RESPAWN:-off}"
export MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT="${MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT:-$HOME/matrix-artifacts/g1-host-getup-v1}"
export MATRIX_PHYSICAL_RECOVERY_PYTHON="${MATRIX_PHYSICAL_RECOVERY_PYTHON:-$HOME/miniconda3/envs/sonic-h2-sim/bin/python}"
export MATRIX_PHYSICAL_RECOVERY_RESIDENT_POLICIES="${MATRIX_PHYSICAL_RECOVERY_RESIDENT_POLICIES:-1}"
export MATRIX_PHYSICAL_RECOVERY_EXECUTION_PROVIDER="${MATRIX_PHYSICAL_RECOVERY_EXECUTION_PROVIDER:-cuda}"
export MATRIX_PHYSICAL_RECOVERY_INITIAL_CONTROLLER="${MATRIX_PHYSICAL_RECOVERY_INITIAL_CONTROLLER:-kungfu}"
export MATRIX_PHYSICAL_RECOVERY_HANDOFF="${MATRIX_PHYSICAL_RECOVERY_HANDOFF:-sonic}"
export MATRIX_PHYSICAL_RECOVERY_MODEL="${MATRIX_PHYSICAL_RECOVERY_MODEL:-$MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT/host_prone_v1_0322.onnx}"
export MATRIX_PHYSICAL_RECOVERY_MODEL_SHA256="${MATRIX_PHYSICAL_RECOVERY_MODEL_SHA256:-62abf58c9a3d50dbe22ba1f950f288795fb3ae54bd3ca6221cc12cb1d45de155}"
export MATRIX_PHYSICAL_RECOVERY_AMP_ROOT="${MATRIX_PHYSICAL_RECOVERY_AMP_ROOT:-$HOME/matrix-artifacts/g1-amp-getup-v1}"
export MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG="${MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG:-$MATRIX_PHYSICAL_RECOVERY_AMP_ROOT/amp_policy_walk_run_getup.json}"
export MATRIX_PHYSICAL_RECOVERY_AMP_MODEL="${MATRIX_PHYSICAL_RECOVERY_AMP_MODEL:-$MATRIX_PHYSICAL_RECOVERY_AMP_ROOT/model_60000.onnx}"
export MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG_SHA256:-f4a4ec20277e67a16104a6d854bf864630159c4320cdf21b789a31ba9a2e5450}"
export MATRIX_PHYSICAL_RECOVERY_AMP_MODEL_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_MODEL_SHA256:-fe96abe1a9d55e2a9b32a2172a2ea8c69b4416cbf2c7923e10d31d133525e82a}"
export MATRIX_KUNGFU_RECOVERY_ROOT="${MATRIX_KUNGFU_RECOVERY_ROOT:-$HOME/matrix-artifacts/kungfu-1307-recovery-v1}"
export MATRIX_KUNGFU_RECOVERY_MODEL="${MATRIX_KUNGFU_RECOVERY_MODEL:-$MATRIX_KUNGFU_RECOVERY_ROOT/policy.onnx}"
export MATRIX_KUNGFU_RECOVERY_MOTION="${MATRIX_KUNGFU_RECOVERY_MOTION:-$MATRIX_KUNGFU_RECOVERY_ROOT/1307-sonic-default-frame15689.npz}"
export MATRIX_KUNGFU_RECOVERY_MODEL_SHA256="${MATRIX_KUNGFU_RECOVERY_MODEL_SHA256:-1c8272f9112df7445fb330033d68d522e42fecf9cbf243e5a67379ee438ce8e3}"
export MATRIX_KUNGFU_RECOVERY_MODEL_DATA_SHA256="${MATRIX_KUNGFU_RECOVERY_MODEL_DATA_SHA256:-03409aed37b4a147ef2c4d3cb90cd5425592f65412d68158bfbbfb0bf86c5956}"
export MATRIX_KUNGFU_RECOVERY_MOTION_SHA256="${MATRIX_KUNGFU_RECOVERY_MOTION_SHA256:-164fb1be98102a6e0ca45ecf9aaf5fd1dedcd28e0cd53bc3bdbd80c9b94ee863}"
export MATRIX_KUNGFU_RECOVERY_REFERENCE_FRAME="${MATRIX_KUNGFU_RECOVERY_REFERENCE_FRAME:-15689}"
export MATRIX_KUNGFU_RECOVERY_GAIN_SCALE="${MATRIX_KUNGFU_RECOVERY_GAIN_SCALE:-1.0}"
export MATRIX_PHYSICAL_RECOVERY_FALLBACK_MODEL="${MATRIX_PHYSICAL_RECOVERY_FALLBACK_MODEL:-$MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT/host_prone_v2_0322.onnx}"
export MATRIX_PHYSICAL_RECOVERY_FALLBACK_AFTER_SECONDS="${MATRIX_PHYSICAL_RECOVERY_FALLBACK_AFTER_SECONDS:-15.0}"
export MATRIX_PHYSICAL_RECOVERY_STABLE_HOLD_SECONDS="${MATRIX_PHYSICAL_RECOVERY_STABLE_HOLD_SECONDS:-1.5}"
export MATRIX_PHYSICAL_RECOVERY_POLICY_EXIT_HOLD_SECONDS="${MATRIX_PHYSICAL_RECOVERY_POLICY_EXIT_HOLD_SECONDS:-0}"
export MATRIX_PHYSICAL_RECOVERY_SONIC_PREWARM_TIMEOUT_SECONDS="${MATRIX_PHYSICAL_RECOVERY_SONIC_PREWARM_TIMEOUT_SECONDS:-120.0}"
