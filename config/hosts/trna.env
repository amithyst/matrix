# Shared, non-secret defaults for the TRNA RTX 5080 Laptop host.
export MATRIX_HOST_PROFILE="trna"
export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-/run/user/$(id -u)/gdm/Xauthority}"
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"
export MATRIX_CPUSET="${MATRIX_CPUSET:-}"

# Keep tmux/Conda shell state out of the locked runtime dependency closure.
unset LD_LIBRARY_PATH PYTHONPATH

# This profile runs the actively developed SONIC worktree. Keep the strict
# immutable-runtime audit opt-in; set MATRIX_VERIFY_RUNTIME=1 for qualification.
export MATRIX_PROFILE_VERIFY_RUNTIME_DEFAULT="${MATRIX_PROFILE_VERIFY_RUNTIME_DEFAULT:-0}"

export MATRIX_RUNTIME_ROOT="${MATRIX_RUNTIME_ROOT:-$MATRIX_PROJECT_ROOT/outputs/runtime/matrix-sonic-native-v2}"
export MATRIX_SONIC_ROOT="${MATRIX_SONIC_ROOT:-$HOME/worktrees/sonic-matrix-recovery-v77}"
# Native re-entry tracing performs synchronous per-event flushes in SONIC
# control callbacks.  Keep that diagnostic path opt-in on TRNA so a large
# trace cannot starve the 50 Hz command producer and trip the 200 ms writer
# watchdog.  Operators can explicitly set this to 0 for a bounded probe run.
export SONIC_DEPLOY_REENTRY_PROBE_DISABLE="${SONIC_DEPLOY_REENTRY_PROBE_DISABLE:-1}"
export MATRIX_BOOTSTRAP_PYTHON="${MATRIX_BOOTSTRAP_PYTHON:-python3.10}"
export MATRIX_ROS_PREFIX="${MATRIX_ROS_PREFIX:-/opt/ros/humble}"
export MATRIX_NATIVE_DEPS_ROOT="${MATRIX_NATIVE_DEPS_ROOT:-$MATRIX_RUNTIME_ROOT/matrix-native-deps}"
export MATRIX_UE_MAX_FPS="${MATRIX_UE_MAX_FPS:-60}"
# The shared inventory only names immutable content digests. Host-local asset
# bytes live in the generic registry, so benchmark packs can be added without
# hard-coding one asset type or another machine's absolute source path.
export MATRIX_ITEM_INVENTORY_CATALOG="${MATRIX_ITEM_INVENTORY_CATALOG:-${MATRIX_CREATIVE_INVENTORY_CATALOG:-$MATRIX_PROJECT_ROOT/config/items/trna-four-way-test.inventory.json}}"
export MATRIX_ITEM_PACK_ROOT="${MATRIX_ITEM_PACK_ROOT:-$HOME/matrix-artifacts/item-packs}"

# Shared TRNA operator defaults. Previously loaded overrides remain authoritative,
# and explicit launcher arguments still win after the profile is loaded.
export MATRIX_SONIC_CONTROL_SOURCE="${MATRIX_SONIC_CONTROL_SOURCE:-game}"
export MATRIX_GAME_INPUT_SOURCE="${MATRIX_GAME_INPUT_SOURCE:-auto}"
export MATRIX_GAME_CAMERA_YAW_SOURCE="${MATRIX_GAME_CAMERA_YAW_SOURCE:-ue-final-pov}"
export MATRIX_GAME_LOOK_BUTTON="${MATRIX_GAME_LOOK_BUTTON:-left}"
export MATRIX_GAME_MOUSE_SENSITIVITY_DEG="${MATRIX_GAME_MOUSE_SENSITIVITY_DEG:-0.12}"
# UE final POV and MuJoCo world yaw advance in the same direction on TRNA.
# The old -1 value belonged to the input-mirror calibration path and made W
# chase a reflected heading instead of the robot's visible forward direction.
export MATRIX_GAME_CAMERA_YAW_SIGN="${MATRIX_GAME_CAMERA_YAW_SIGN:-1}"
export MATRIX_GAME_CAMERA_YAW_OFFSET_DEG="${MATRIX_GAME_CAMERA_YAW_OFFSET_DEG:-0.0}"
# Shared motion defaults stay in the host profile; panel/API overrides are
# persisted separately under ~/.config/matrix/hosts/trna/motion-control.json.
export MATRIX_GAME_KEYBOARD_SLOW_SPEED="${MATRIX_GAME_KEYBOARD_SLOW_SPEED:-0.10}"
export MATRIX_GAME_KEYBOARD_SLOW_BOOST_SPEED="${MATRIX_GAME_KEYBOARD_SLOW_BOOST_SPEED:-0.20}"
export MATRIX_GAME_KEYBOARD_WALK_SPEED="${MATRIX_GAME_KEYBOARD_WALK_SPEED:-0.80}"
export MATRIX_GAME_KEYBOARD_WALK_BOOST_SPEED="${MATRIX_GAME_KEYBOARD_WALK_BOOST_SPEED:-1.00}"
export MATRIX_GAME_KEYBOARD_RUN_SPEED="${MATRIX_GAME_KEYBOARD_RUN_SPEED:-2.50}"
export MATRIX_GAME_KEYBOARD_RUN_BOOST_SPEED="${MATRIX_GAME_KEYBOARD_RUN_BOOST_SPEED:-2.75}"
export MATRIX_GAME_KEYBOARD_DOUBLE_TAP_WINDOW="${MATRIX_GAME_KEYBOARD_DOUBLE_TAP_WINDOW:-0.30}"
# An explicitly empty inherited value keeps the signed overlay disabled for a
# recovery/debug launch.
export MATRIX_CENTERED_CAMERA_OVERLAY_BUNDLE="${MATRIX_CENTERED_CAMERA_OVERLAY_BUNDLE-$HOME/matrix-artifacts/matrix-centered-camera-custom-v1}"

# Create the capability-gated virtual engine devices before UE starts so SDL
# can enumerate them. The helper opens /dev/uinput through non-interactive sudo,
# immediately drops to the TRNA user, and is owned by the launcher lifecycle.
export MATRIX_ENGINE_INPUT_BRIDGE="${MATRIX_ENGINE_INPUT_BRIDGE:-1}"

# TRNA recovery test deployment. Keep the persistent world enabled, while
# physical recovery owns the fall path instead of the cold auto-respawn loop.
export MATRIX_GAME_AUTO_RESPAWN="${MATRIX_GAME_AUTO_RESPAWN:-off}"
export MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT="${MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT:-$HOME/matrix-artifacts/g1-host-getup-v1}"
export MATRIX_PHYSICAL_RECOVERY_PYTHON="${MATRIX_PHYSICAL_RECOVERY_PYTHON:-$HOME/miniconda3/envs/sonic-h2-sim/bin/python}"
export MATRIX_PHYSICAL_RECOVERY_RESIDENT_POLICIES="${MATRIX_PHYSICAL_RECOVERY_RESIDENT_POLICIES:-1}"
export MATRIX_PHYSICAL_RECOVERY_EXECUTION_PROVIDER="${MATRIX_PHYSICAL_RECOVERY_EXECUTION_PROVIDER:-cuda}"
export MATRIX_PHYSICAL_RECOVERY_INITIAL_CONTROLLER="${MATRIX_PHYSICAL_RECOVERY_INITIAL_CONTROLLER:-kungfu}"
export MATRIX_PHYSICAL_RECOVERY_HANDOFF="${MATRIX_PHYSICAL_RECOVERY_HANDOFF:-sonic}"
export MATRIX_PHYSICAL_RECOVERY_MODEL="${MATRIX_PHYSICAL_RECOVERY_MODEL:-$MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT/host_prone_v1_0322.onnx}"
export MATRIX_PHYSICAL_RECOVERY_MODEL_SHA256="${MATRIX_PHYSICAL_RECOVERY_MODEL_SHA256:-62abf58c9a3d50dbe22ba1f950f288795fb3ae54bd3ca6221cc12cb1d45de155}"
export MATRIX_PHYSICAL_RECOVERY_AMP_ROOT="${MATRIX_PHYSICAL_RECOVERY_AMP_ROOT:-$HOME/matrix-artifacts/g1-amp-getup-v1}"
export MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG="${MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG:-$MATRIX_PHYSICAL_RECOVERY_AMP_ROOT/amp_policy_walk_run_getup.json}"
export MATRIX_PHYSICAL_RECOVERY_AMP_MODEL="${MATRIX_PHYSICAL_RECOVERY_AMP_MODEL:-$MATRIX_PHYSICAL_RECOVERY_AMP_ROOT/model_60000.onnx}"
export MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_CONFIG_SHA256:-f4a4ec20277e67a16104a6d854bf864630159c4320cdf21b789a31ba9a2e5450}"
export MATRIX_PHYSICAL_RECOVERY_AMP_MODEL_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_MODEL_SHA256:-fe96abe1a9d55e2a9b32a2172a2ea8c69b4416cbf2c7923e10d31d133525e82a}"
# Shizhanxu/Jiamandu flat_v3 remains a separately selectable recovery slot.
# Its ONNX embeds the checkpoint's empirical observation normalizer.
export MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_ROOT="${MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_ROOT:-$HOME/matrix-artifacts/g1-amp-flat-v3-getup-v1}"
export MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_CONFIG="${MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_CONFIG:-$MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_ROOT/amp_policy_flat_v3_m14000.json}"
export MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_MODEL="${MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_MODEL:-$MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_ROOT/flat_v3_m14000.onnx}"
export MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_CONFIG_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_CONFIG_SHA256:-c3624d6a4a7ec12498264ea9505060399389c5b759867c3141b8191361c88adf}"
export MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_MODEL_SHA256="${MATRIX_PHYSICAL_RECOVERY_AMP_FLAT_V3_MODEL_SHA256:-243eb1bd91a0414bceeb7042e75d58ac1f0709dbe975cda15df088298ed93803}"
export MATRIX_KUNGFU_RECOVERY_ROOT="${MATRIX_KUNGFU_RECOVERY_ROOT:-$HOME/matrix-artifacts/kungfu-1307-recovery-v1}"
export MATRIX_KUNGFU_RECOVERY_MODEL="${MATRIX_KUNGFU_RECOVERY_MODEL:-$MATRIX_KUNGFU_RECOVERY_ROOT/policy.onnx}"
export MATRIX_KUNGFU_RECOVERY_MOTION="${MATRIX_KUNGFU_RECOVERY_MOTION:-$MATRIX_KUNGFU_RECOVERY_ROOT/1307-sonic-default-frame15689.npz}"
export MATRIX_KUNGFU_RECOVERY_MODEL_SHA256="${MATRIX_KUNGFU_RECOVERY_MODEL_SHA256:-1c8272f9112df7445fb330033d68d522e42fecf9cbf243e5a67379ee438ce8e3}"
export MATRIX_KUNGFU_RECOVERY_MODEL_DATA_SHA256="${MATRIX_KUNGFU_RECOVERY_MODEL_DATA_SHA256:-03409aed37b4a147ef2c4d3cb90cd5425592f65412d68158bfbbfb0bf86c5956}"
export MATRIX_KUNGFU_RECOVERY_MOTION_SHA256="${MATRIX_KUNGFU_RECOVERY_MOTION_SHA256:-164fb1be98102a6e0ca45ecf9aaf5fd1dedcd28e0cd53bc3bdbd80c9b94ee863}"
export MATRIX_KUNGFU_RECOVERY_REFERENCE_FRAME="${MATRIX_KUNGFU_RECOVERY_REFERENCE_FRAME:-15689}"
export MATRIX_KUNGFU_RECOVERY_GAIN_SCALE="${MATRIX_KUNGFU_RECOVERY_GAIN_SCALE:-1.0}"
export MATRIX_PHYSICAL_RECOVERY_FALLBACK_MODEL="${MATRIX_PHYSICAL_RECOVERY_FALLBACK_MODEL:-$MATRIX_PHYSICAL_RECOVERY_ARTIFACT_ROOT/host_prone_v2_0322.onnx}"
export MATRIX_PHYSICAL_RECOVERY_FALLBACK_AFTER_SECONDS="${MATRIX_PHYSICAL_RECOVERY_FALLBACK_AFTER_SECONDS:-15.0}"
export MATRIX_PHYSICAL_RECOVERY_STABLE_HOLD_SECONDS="${MATRIX_PHYSICAL_RECOVERY_STABLE_HOLD_SECONDS:-1.5}"
export MATRIX_PHYSICAL_RECOVERY_POLICY_EXIT_HOLD_SECONDS="${MATRIX_PHYSICAL_RECOVERY_POLICY_EXIT_HOLD_SECONDS:-0}"
export MATRIX_PHYSICAL_RECOVERY_SONIC_PREWARM_TIMEOUT_SECONDS="${MATRIX_PHYSICAL_RECOVERY_SONIC_PREWARM_TIMEOUT_SECONDS:-120.0}"

# Terrain-aware BFM-Teacher50k remains a resident shadow until the policy panel
# requests a neutral/upright writer handoff.  Every path is host-local while
# the shared manifest locks the source commits and content hashes.
export MATRIX_BFM_SONIC_PYTHON="${MATRIX_BFM_SONIC_PYTHON:-$MATRIX_PHYSICAL_RECOVERY_PYTHON}"
export MATRIX_BFM_SONIC_ARTIFACT_ROOT="${MATRIX_BFM_SONIC_ARTIFACT_ROOT:-$HOME/matrix-artifacts/bfm-teacher50k-matrix-v1}"
export MATRIX_BFM_SONIC_SOURCE_ROOT="${MATRIX_BFM_SONIC_SOURCE_ROOT:-$HOME/metabot-workspace/bfm-sonic-teacher50k-matrix-20260723}"
export MATRIX_BFM_RESCAN_SOURCE_ROOT="${MATRIX_BFM_RESCAN_SOURCE_ROOT:-$HOME/metabot-workspace/bfm-sonic-realscan-play-matrix-20260723}"
export MATRIX_ROBO_PFNN_SOURCE_ROOT="${MATRIX_ROBO_PFNN_SOURCE_ROOT:-$HOME/metabot-workspace/robo-pfnn-matrix-runtime-20260723}"
export MATRIX_BFM_SONIC_CHECKPOINT="${MATRIX_BFM_SONIC_CHECKPOINT:-$MATRIX_BFM_SONIC_ARTIFACT_ROOT/input/model_step_050000.pt}"
export MATRIX_BFM_SONIC_CONFIG="${MATRIX_BFM_SONIC_CONFIG:-$MATRIX_BFM_SONIC_ARTIFACT_ROOT/input/config.yaml}"
export MATRIX_BFM_SONIC_TEACHER_ONNX="${MATRIX_BFM_SONIC_TEACHER_ONNX:-$MATRIX_BFM_SONIC_ARTIFACT_ROOT/export/model_step_050000_g1.onnx}"
export MATRIX_BFM_SONIC_RUNTIME_ADAPTER="${MATRIX_BFM_SONIC_RUNTIME_ADAPTER:-$MATRIX_PROJECT_ROOT/scripts/matrix_bfm_teacher_adapter.py}"
export MATRIX_BFM_SONIC_PFNN_WEIGHTS="${MATRIX_BFM_SONIC_PFNN_WEIGHTS:-$MATRIX_BFM_SONIC_SOURCE_ROOT/scripts/bfm_sonic_data/formal7168/vendor/robo_pfnn_weights}"
export MATRIX_BFM_SONIC_FORMAL_IK="${MATRIX_BFM_SONIC_FORMAL_IK:-$MATRIX_BFM_SONIC_SOURCE_ROOT/scripts/bfm_sonic_data/formal7168/overlays/robo_pfnn/robo_pfnn/runtime/pfnn_ik.py}"
export MATRIX_BFM_SONIC_G1_XML="${MATRIX_BFM_SONIC_G1_XML:-$MATRIX_ROBO_PFNN_SOURCE_ROOT/third_party/holosoma_retargeting/holosoma_retargeting/models/g1/g1_29dof.xml}"
export MATRIX_BFM_SONIC_ACTIVATION_BLEND_SECONDS="${MATRIX_BFM_SONIC_ACTIVATION_BLEND_SECONDS:-0.10}"
