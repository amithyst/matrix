# Shared, non-secret defaults for the ZZA Ubuntu RTX 4090 host.
export MATRIX_HOST_PROFILE="zza"
export DISPLAY="${DISPLAY:-:1}"
export XAUTHORITY="${XAUTHORITY:-/run/user/$(id -u)/gdm/Xauthority}"
export CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"

# ZZA has one 24-core NUMA node, so an explicit CPU affinity adds no locality.
export MATRIX_CPUSET="${MATRIX_CPUSET:-}"

export MATRIX_RUNTIME_ROOT="${MATRIX_RUNTIME_ROOT:-$MATRIX_PROJECT_ROOT/outputs/runtime/matrix-sonic-v1}"
export MATRIX_BOOTSTRAP_PYTHON="${MATRIX_BOOTSTRAP_PYTHON:-python3.10}"
export MATRIX_ROS_PREFIX="${MATRIX_ROS_PREFIX:-$MATRIX_RUNTIME_ROOT/ros2-humble-prefix}"
export MATRIX_NATIVE_DEPS_ROOT="${MATRIX_NATIVE_DEPS_ROOT:-$MATRIX_RUNTIME_ROOT/matrix-native-deps}"
export MATRIX_UE_MAX_FPS="${MATRIX_UE_MAX_FPS:-60}"

# ZZA has no system jq or unattended package install. Keep tools user-local.
export MATRIX_TOOLS_ROOT="${MATRIX_TOOLS_ROOT:-$HOME/.local}"
export PATH="$MATRIX_TOOLS_ROOT/bin:$PATH"
